APP_NAME=SVMP
APP_ENV=development
LOG_LEVEL=INFO
PORT=8000

MONGODB_DB_NAME=svmp
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
MONGODB_SESSION_COLLECTION=session_state
MONGODB_KB_COLLECTION=knowledge_base
MONGODB_GOVERNANCE_COLLECTION=governance_logs
MONGODB_TENANTS_COLLECTION=tenants

OPENAI_API_KEY=replace-with-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
USE_OPENAI_MATCHER=true
OPENAI_SHADOW_MODE=false
OPENAI_MATCHER_CANDIDATE_LIMIT=8

# Fallback provider used only when a session has no stored provider yet.
# In normal operation, outbound replies follow the inbound session provider.
WHATSAPP_PROVIDER=normalized

# Meta WhatsApp Business credentials.
WHATSAPP_TOKEN=replace-with-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
WHATSAPP_VERIFY_TOKEN=replace-with-meta-verify-token

# Twilio WhatsApp Sandbox / virtual demo credentials.
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

DEBOUNCE_MS=2500
SIMILARITY_THRESHOLD=0.75
WORKFLOW_B_INTERVAL_SECONDS=1
WORKFLOW_C_INTERVAL_HOURS=24
