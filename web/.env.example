NEXT_PUBLIC_API_BASE_URL=https://api.svmpsystems.com

# Production default. Supabase verifies identity; the backend resolves tenant access.
NEXT_PUBLIC_PORTAL_AUTH_MODE=supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_project_key

# Temporary preview mode needs both:
# NEXT_PUBLIC_PORTAL_AUTH_MODE=preview
# PORTAL_ALLOW_UNSAFE_PREVIEW_AUTH=true
# Do not enable preview auth for paid-client production access.
PORTAL_ALLOW_UNSAFE_PREVIEW_AUTH=false
PORTAL_PREVIEW_ALLOWED_EMAILS=prnvvh@gmail.com
PORTAL_PREVIEW_PASSWORD=replace_with_a_strong_temporary_password
PORTAL_PREVIEW_AUTH_SECRET=replace_with_a_long_random_session_secret
PORTAL_PREVIEW_TENANT_ID=stay
PORTAL_PREVIEW_TENANT_NAME=Stay Parfums

# Billing mode mirrors the backend runtime.
NEXT_PUBLIC_BILLING_MODE=manual
