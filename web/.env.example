NEXT_PUBLIC_API_BASE_URL=https://api.svmpsystems.com

# Production default. Clerk verifies identity; MongoDB verified_users resolves tenant access.
NEXT_PUBLIC_PORTAL_AUTH_MODE=clerk

# Temporary preview mode needs both:
# NEXT_PUBLIC_PORTAL_AUTH_MODE=preview
# PORTAL_ALLOW_UNSAFE_PREVIEW_AUTH=true
# Do not enable preview auth for paid-client production access.
PORTAL_ALLOW_UNSAFE_PREVIEW_AUTH=false
PORTAL_PREVIEW_ALLOWED_EMAILS=prnvvh@gmail.com
PORTAL_PREVIEW_PASSWORD=replace_with_a_strong_temporary_password
PORTAL_PREVIEW_AUTH_SECRET=replace_with_a_long_random_session_secret
PORTAL_PREVIEW_TENANT_ID=stay
PORTAL_PREVIEW_TENANT_NAME=Stay Parfums

# Clerk frontend configuration
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_with_clerk_publishable_key
CLERK_SECRET_KEY=sk_live_replace_with_clerk_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup

# Recommended: use a custom Clerk JWT template for backend bearer tokens.
# Include email in the token if you want email-only invites to bind on first login.
# Pair this with CLERK_JWT_TEMPLATE on the frontend server and CLERK_AUDIENCE on FastAPI.
CLERK_JWT_TEMPLATE=svmp-dashboard
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=svmp-dashboard

# Pilot billing is manually approved in MongoDB. Set to stripe later when checkout is enabled.
NEXT_PUBLIC_BILLING_MODE=manual
